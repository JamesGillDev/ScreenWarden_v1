<Window x:Class="ScreenWarden.Controls.VoiceCommandEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Command" Width="350" Height="180"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="Phrase:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="PhraseTextBox" Grid.Column="1" Margin="0,0,0,8" Padding="4"/>
        
        <TextBlock Grid.Row="1" Text="Action:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox x:Name="ActionComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>
        
        <TextBlock Grid.Row="2" Text="Enabled:" VerticalAlignment="Center"/>
        <CheckBox x:Name="EnabledCheckBox" Grid.Row="2" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
        
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="70" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
